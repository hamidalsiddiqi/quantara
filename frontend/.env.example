# Base URL for the backend API. Must include the version prefix.
#
# Dev (Vite proxy handles forwarding to the backend in vite.config.ts):
#   VITE_API_BASE_URL=/api/v1
#
# Production (point directly at the deployed backend):
#   VITE_API_BASE_URL=https://quantara-0qp4.onrender.com/api/v1
VITE_API_BASE_URL=/api/v1

# Dev-only: where the Vite dev-server proxy forwards /api requests.
# Not used in production builds.
VITE_DEV_API_PROXY=https://quantara-0qp4.onrender.com
