generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  username           String   @unique
  passwordHash       String
  isAdmin            Boolean  @default(false)
  bscDepositAddress  String?  @unique
  bscDepositIndex    Int?     @unique
  bscWithdrawAddress String?
  referralCode       String?  @unique
  referrerId         String?
  isBanned           Boolean  @default(false)
  adminBalance       Decimal  @default(0) @db.Decimal(36, 18)
  adminProfits       Decimal  @default(0) @db.Decimal(36, 18)
  createdAt          DateTime @default(now())

  referrer  User?  @relation("UserReferrals", fields: [referrerId], references: [id])
  referrals User[] @relation("UserReferrals")

  cycles            Cycle[]
  deposits          Deposit[]
  withdrawals       Withdrawal[]
  earnings          Earning[]
  referralEarnings  ReferralEarning[] @relation("ReferralEarner")
  sourcedReferrals  ReferralEarning[] @relation("ReferralSource")

  @@index([referrerId])
}

enum CycleTier {
  STARTER
  PRO
  ELITE
}

enum CycleStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Cycle {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  tier         CycleTier
  principal    Decimal     @db.Decimal(36, 18)
  dailyRoiBps  Int
  durationDays Int
  startedAt    DateTime    @default(now())
  endsAt       DateTime
  status       CycleStatus @default(ACTIVE)
  daysAccrued  Int         @default(0)
  totalAccrued Decimal     @db.Decimal(36, 18) @default(0)

  earnings Earning[]

  @@index([userId, status])
  @@index([status, endsAt])
}

enum EarningKind {
  ROI
  PRINCIPAL_RELEASE
}

model Earning {
  id        String      @id @default(cuid())
  userId    String
  cycleId   String
  amount    Decimal     @db.Decimal(36, 18)
  kind      EarningKind @default(ROI)
  accruedOn DateTime
  createdAt DateTime    @default(now())

  user  User  @relation(fields: [userId], references: [id])
  cycle Cycle @relation(fields: [cycleId], references: [id])

  @@unique([cycleId, accruedOn])
  @@index([userId, createdAt])
}

enum DepositStatus {
  PENDING
  CONFIRMED
  CREDITED
  FAILED
}

model Deposit {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  txHash        String        @unique
  logIndex      Int           @default(0)
  fromAddress   String
  toAddress     String
  amount        Decimal       @db.Decimal(36, 18)
  blockNumber   Int
  confirmations Int           @default(0)
  status        DepositStatus @default(PENDING)
  cycleId       String?
  createdAt     DateTime      @default(now())

  @@index([status])
  @@index([userId, createdAt])
}

enum WithdrawStatus {
  PENDING
  SIGNED
  BROADCAST
  CONFIRMED
  FAILED
}

model Withdrawal {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  toAddress   String
  amount      Decimal        @db.Decimal(36, 18) // gross amount debited from balance
  fee         Decimal        @default(0) @db.Decimal(36, 18) // withdrawal fee retained by platform
  netAmount   Decimal        @default(0) @db.Decimal(36, 18) // amount actually sent on-chain (amount - fee)
  status      WithdrawStatus @default(PENDING)
  requestId   String         @unique
  txHash      String?
  error       String?
  createdAt   DateTime       @default(now())
  processedAt DateTime?

  @@index([status])
  @@index([userId, createdAt])
}

model Setting {
  key   String @id
  value String
}

model ReferralEarning {
  id           String   @id @default(cuid())
  userId       String   // upline user receiving the commission
  user         User     @relation("ReferralEarner", fields: [userId], references: [id])
  sourceUserId String   // downline user whose deposit generated the commission
  sourceUser   User     @relation("ReferralSource", fields: [sourceUserId], references: [id])
  cycleId      String   // the cycle that triggered the commission
  depositId    String?  // the originating deposit (if known)
  level        Int      // 1..6
  bps          Int      // basis points used for this level (1200 = 12%)
  amount       Decimal  @db.Decimal(36, 18)
  createdAt    DateTime @default(now())

  @@unique([cycleId, userId, level])
  @@index([userId, createdAt])
  @@index([sourceUserId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, createdAt(sort: Desc)])
}
